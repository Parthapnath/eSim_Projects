X A1 7 -500 500 200 R 50 50 1 1 I
X B1 8 -500 400 200 R 50 50 1 1 I
X OUT4 9 600 -350 200 L 50 50 1 1 O
X OUT2 10 600 -50 200 L 50 50 1 1 O
X OUT3 11 600 -200 200 L 50 50 1 1 O
X OUT1 12 600 100 200 L 50 50 1 1 O
X GND 13 -500 -650 200 R 50 50 1 1 I
X VCC 14 -500 -550 200 R 50 50 1 1 I
ENDDRAW
ENDDEF
#
# plot_v1
#
DEF plot_v1 U 0 40 Y Y 1 F N
F0 "U" 0 500 60 H V C CNN
